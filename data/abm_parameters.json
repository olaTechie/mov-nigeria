[{"Category":"Population","Parameter":"Number of providers","Symbol":"N_p","Value":"500","Range":"200-1,000","Source":"Scaled from NDHS 2024 cluster count","Notes":"Represents health workers across facility types"},{"Category":"Population","Parameter":"Number of caregivers","Symbol":"N_c","Value":"5,000","Range":"2,000-10,000","Source":"Scaled from NDHS 2024 analytic sample","Notes":"Mothers of children 12-23 months"},{"Category":"Population","Parameter":"Resistant provider fraction","Symbol":"f_resist","Value":"0.15","Range":"0.05-0.25","Source":"Assumption based on facility surveys","Notes":"Providers who do not respond to peer influence or supervision"},{"Category":"Network","Parameter":"Provider network type","Symbol":"-","Value":"Watts-Strogatz","Range":"-","Source":"Standard small-world model","Notes":"Captures clustered collegial relationships with short-cuts"},{"Category":"Network","Parameter":"Provider neighbours (k)","Symbol":"k_p","Value":"4","Range":"2-8","Source":"Assumption; typical facility team size","Notes":"Number of nearest neighbours in ring lattice"},{"Category":"Network","Parameter":"Provider rewiring (p)","Symbol":"p_p","Value":"0.10","Range":"0.05-0.20","Source":"Small-world convention","Notes":"Probability of rewiring each edge"},{"Category":"Network","Parameter":"Caregiver network type","Symbol":"-","Value":"Watts-Strogatz","Range":"-","Source":"Standard small-world model","Notes":"Captures community social structure"},{"Category":"Network","Parameter":"Caregiver neighbours (k)","Symbol":"k_c","Value":"6","Range":"4-10","Source":"DHS cluster size proxy","Notes":"Reflects typical social network degree in Nigerian communities"},{"Category":"Network","Parameter":"Caregiver rewiring (p)","Symbol":"p_c","Value":"0.15","Range":"0.05-0.25","Source":"Assumption","Notes":"Slightly higher than provider to reflect broader social ties"},{"Category":"Behaviour","Parameter":"Provider peer influence","Symbol":"\u03b2\u2081","Value":"0.15","Range":"0.05-0.